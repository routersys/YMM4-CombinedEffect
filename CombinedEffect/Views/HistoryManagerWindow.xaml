<Window x:Class="CombinedEffect.Views.HistoryManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:CombinedEffect.Localization"
        xmlns:infra="clr-namespace:CombinedEffect.Infrastructure"
        Title="{Binding WindowTitle}" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
    <Window.Resources>
        <infra:UtcToLocalTimeConverter x:Key="UtcToLocal" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static loc:Texts.History_Branch}" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox Grid.Row="1" ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" Background="Transparent" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" Padding="5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" VerticalContentAlignment="Center" Padding="4"/>
                <Button Grid.Row="1" Command="{Binding CreateBranchCommand}" Content="{x:Static loc:Texts.History_NewBranch}" Padding="15,5"/>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static loc:Texts.History_Snapshot}" FontWeight="Bold" Margin="0,0,0,5"/>

            <ListView Grid.Row="1" ItemsSource="{Binding Snapshots}" SelectedItem="{Binding SelectedSnapshot}" Background="Transparent" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="{x:Static loc:Texts.History_Merge}"
                                              Command="{Binding PlacementTarget.Tag.MergeSnapshotCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static loc:Texts.History_ResetSoft}"
                                              Command="{Binding PlacementTarget.Tag.ResetSoftCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="{x:Static loc:Texts.History_ResetHard}"
                                              Command="{Binding PlacementTarget.Tag.ResetHardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static loc:Texts.History_ManageTags}"
                                              Command="{Binding PlacementTarget.Tag.ManageTagsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static loc:Texts.History_ColumnMessage}" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="-6,0,-6,0" VerticalAlignment="Stretch">
                                        <Rectangle Width="2" Fill="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" VerticalAlignment="Stretch" Margin="10,0,0,0" HorizontalAlignment="Left" />
                                        <StackPanel Orientation="Horizontal" Margin="6,5,5,5">
                                            <Grid Width="10" Height="10" Margin="0,0,5,0">
                                                <Ellipse Fill="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"/>
                                                <Ellipse x:Name="CommitIcon" Stroke="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" StrokeThickness="2" Fill="Transparent" />
                                            </Grid>
                                            <TextBlock Text="{Binding DisplayTags}" Foreground="MediumSeaGreen" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding Message}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter TargetName="CommitIcon" Property="Fill" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static loc:Texts.History_ColumnTime}" Width="150" DisplayMemberBinding="{Binding Timestamp, Converter={StaticResource UtcToLocal}}"/>
                        <GridViewColumn Header="{x:Static loc:Texts.History_Changes}" Width="100" DisplayMemberBinding="{Binding DiffSummary}"/>
                        <GridViewColumn Header="{x:Static loc:Texts.History_ColumnID}" Width="100" DisplayMemberBinding="{Binding Id}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SnapshotMessage, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" VerticalContentAlignment="Center" Padding="4"/>
                <Button Grid.Column="1" Command="{Binding CreateSnapshotCommand}" Content="{x:Static loc:Texts.History_NewSnapshot}" Padding="15,5"/>
            </Grid>

            <Button Grid.Row="3" Command="{Binding RevertSnapshotCommand}" Content="{x:Static loc:Texts.History_Revert}" Padding="15,5" FontWeight="Bold"/>
        </Grid>

        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent"/>

        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static loc:Texts.History_Changes}" FontWeight="Bold" Margin="0,0,0,5"/>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ParameterDiffList}" FontFamily="Consolas">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Added">
                                                <Setter Property="Foreground" Value="MediumSeaGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Removed">
                                                <Setter Property="Foreground" Value="IndianRed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Type}" Value="Modified">
                                                <Setter Property="Foreground" Value="Goldenrod" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>