<UserControl x:Class="CombinedEffect.Views.PresetManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:CombinedEffect.Localization"
             xmlns:vm="clr-namespace:CombinedEffect.ViewModels"
             xmlns:converters="clr-namespace:CombinedEffect.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="700"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <converters:FavoriteStarBrushConverter x:Key="FavoriteStarBrushConverter"/>

        <Style x:Key="AnimatedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="MaxWidth" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="200" Duration="0:0:0.15" DecelerationRatio="0.9"/>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="5,0,5,0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="MaxWidth" To="0" Duration="0:0:0.15" DecelerationRatio="0.9"/>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin" To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Focusable="False">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="VerticalGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="SizeWE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent">
                            <Border Width="1" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="RootBorder" Margin="5,5,5,0"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                BorderThickness="1">
            <Grid x:Name="RootControl" SizeChanged="RootControl_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="GroupColumn" Width="150" MinWidth="120" MaxWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="GroupPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="GroupListBox" Grid.Row="0" Margin="0"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             AllowDrop="True"
                             PreviewMouseWheel="ListBox_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GroupItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="MouseMove" Handler="GroupItem_MouseMove"/>
                                <EventSetter Event="DragEnter" Handler="GroupItem_DragEnter"/>
                                <EventSetter Event="DragLeave" Handler="GroupItem_DragLeave"/>
                                <EventSetter Event="Drop" Handler="GroupItem_Drop"/>
                                <EventSetter Event="MouseDoubleClick" Handler="GroupItem_MouseDoubleClick"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="24" Background="Transparent">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                        <Button Command="{Binding AddGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_AddGroup}" Width="28" Height="28" Padding="0">
                            <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button Command="{Binding RemoveGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_RemoveGroup}" Width="28" Height="28" Padding="0">
                            <Path Data="M19 13H5v-2h14v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <GridSplitter x:Name="GroupSplitter" Grid.Column="1" Style="{StaticResource VerticalGridSplitterStyle}" DragCompleted="GridSplitter_DragCompleted"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="MobileMenuButton" Grid.Column="0" VerticalAlignment="Center" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                            <Path Data="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" Fill="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" Stretch="Uniform" Width="16" Height="16"/>
                        </ToggleButton>
                        <Popup x:Name="MobileGroupPopup" PlacementTarget="{Binding ElementName=MobileMenuButton}" Placement="Bottom" StaysOpen="False" IsOpen="{Binding IsChecked, ElementName=MobileMenuButton, Mode=TwoWay}">
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" Width="200" Height="250" Padding="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ListBox x:Name="MobileGroupListBox" Grid.Row="0"
                                             ItemsSource="{Binding Groups}"
                                             SelectedItem="{Binding SelectedGroup}"
                                             AllowDrop="True"
                                             PreviewMouseWheel="ListBox_PreviewMouseWheel">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="AllowDrop" Value="True"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GroupItem_PreviewMouseLeftButtonDown"/>
                                                <EventSetter Event="MouseMove" Handler="GroupItem_MouseMove"/>
                                                <EventSetter Event="DragEnter" Handler="GroupItem_DragEnter"/>
                                                <EventSetter Event="DragLeave" Handler="GroupItem_DragLeave"/>
                                                <EventSetter Event="Drop" Handler="GroupItem_Drop"/>
                                                <EventSetter Event="MouseDoubleClick" Handler="GroupItem_MouseDoubleClick"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="24" Background="Transparent">
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                                        <Button Command="{Binding AddGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_AddGroup}" Width="28" Height="28" Padding="0">
                                            <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </Button>
                                        <Button Command="{Binding RemoveGroupCommand}" ToolTip="{x:Static loc:Texts.PresetManager_RemoveGroup}" Width="28" Height="28" Padding="0">
                                            <Path Data="M19 13H5v-2h14v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>

                        <Grid Grid.Column="1" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0"
                                  Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                  Stretch="Uniform"
                                  Width="14" Height="14"
                                  Margin="6,0,4,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Padding="0,6" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Static loc:Texts.PresetManager_SearchPlaceholder}"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Menu Grid.Column="2" Background="Transparent" VerticalAlignment="Center" Margin="0" Padding="0">
                                <MenuItem Width="28" Height="28" Padding="0" BorderThickness="0" Background="Transparent" ToolTip="{x:Static loc:Texts.SearchMode_Tooltip}">
                                    <MenuItem.Header>
                                        <Grid Width="28" Height="28" Background="Transparent">
                                            <Path Data="M3 5v2h2V5H3zm4 0v2h14V5H7zM11 11v2h2v-2h-2zm-8 0v2h6v-2H3zm12 0v2h6v-2h-6zM7 17v2h2v-2H7zm-4 0v2h2v-2H3zm8 0v2h10v-2H11z"
                                                  Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                  Stretch="Uniform" Width="14" Height="14"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_Name}" IsChecked="{Binding IsSearchModeName, Mode=OneWay}" Command="{Binding SetSearchModeCommand}" CommandParameter="Name"/>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_EffectName}" IsChecked="{Binding IsSearchModeEffectName, Mode=OneWay}" Command="{Binding SetSearchModeCommand}" CommandParameter="EffectName"/>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_EffectCount}" IsChecked="{Binding IsSearchModeEffectCount, Mode=OneWay}" Command="{Binding SetSearchModeCommand}" CommandParameter="EffectCount"/>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_RawJson}" IsChecked="{Binding IsSearchModeRawJson, Mode=OneWay}" Command="{Binding SetSearchModeCommand}" CommandParameter="RawJson"/>
                                    <MenuItem Header="{x:Static loc:Texts.SearchMode_Any}" IsChecked="{Binding IsSearchModeAny, Mode=OneWay}" Command="{Binding SetSearchModeCommand}" CommandParameter="Any"/>
                                </MenuItem>
                            </Menu>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

                    <ListBox x:Name="PresetListBox" Grid.Row="2" Margin="0"
                             ItemsSource="{Binding DisplayedPresets}"
                             SelectedItem="{Binding SelectedPreset}"
                             SelectionMode="Extended"
                             AllowDrop="True"
                             PreviewMouseWheel="ListBox_PreviewMouseWheel">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{x:Static loc:Texts.PresetManager_ExchangeImport}"
                                          Command="{Binding PlacementTarget.DataContext.ImportPresetsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <Separator/>
                                <MenuItem Header="{x:Static loc:Texts.PresetManager_Clear}">
                                    <MenuItem Header="{x:Static loc:Texts.PresetManager_ClearUnselected}"
                                              Command="{Binding PlacementTarget.DataContext.ClearUnselectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="AllowDrop" Value="True"/>
                                <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ApplyPreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ApplySinglePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_UpdatePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.UpdatePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_RenamePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.RenamePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_RemovePreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.RemovePresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ClearPreset}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ClearPresetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.PresetManager_ExchangeExport}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ExportPresetsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.Tag.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <Separator/>
                                            <MenuItem Header="{x:Static loc:Texts.History_Manage}"
                                                      Command="{Binding PlacementTarget.Tag.DataContext.ManageHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="PresetItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="MouseMove" Handler="PresetItem_MouseMove"/>
                                <EventSetter Event="DragEnter" Handler="PresetItem_DragEnter"/>
                                <EventSetter Event="DragLeave" Handler="PresetItem_DragLeave"/>
                                <EventSetter Event="Drop" Handler="PresetItem_Drop"/>
                                <EventSetter Event="MouseDoubleClick" Handler="PresetItem_MouseDoubleClick"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="PresetItem_PreviewMouseRightButtonDown"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="24" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource StarButtonStyle}"
                                            Width="24" Height="24" Padding="0" Margin="0,0,4,0">
                                        <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center" HorizontalAlignment="Center"
                                              Fill="{Binding IsFavorite, Converter={StaticResource FavoriteStarBrushConverter}}"/>
                                    </Button>

                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding Name}"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding EffectCount}"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>

                                    <Border Grid.Column="3" Width="16" Height="16" Background="Transparent"
                                            VerticalAlignment="Center" Margin="0,0,4,0" Cursor="Help">
                                        <Border.ToolTip>
                                            <ToolTip Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                                     Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                                                     BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                     BorderThickness="1"
                                                     Placement="Right"
                                                     HasDropShadow="False">
                                                <TextBlock Text="{Binding EffectInfo}" LineHeight="16" />
                                            </ToolTip>
                                        </Border.ToolTip>
                                        <Path Data="M11 7h2v2h-2zm0 4h2v6h-2zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"
                                              Fill="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                              Stretch="Uniform" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <Button Command="{Binding AddPresetCommand}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_AddPreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_AddPreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding RemovePresetCommand}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_RemovePreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <Path Data="M19 13H5v-2h14v2z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_RemovePreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding UpdatePresetCommand}" Padding="0" Height="28" MinWidth="28" ToolTip="{x:Static loc:Texts.PresetManager_UpdatePreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <Path Data="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79 2.73 2.71 7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.5-1.06 4.84-2.98 6.78-3.87 3.86-10.15 3.86-14.02 0-3.87-3.86-3.87-10.15 0-14.01 3.87-3.86 10.15-3.86 14.02 0L21 1.9v8.22z" Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_UpdatePreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                            <Button Command="{Binding ApplyPresetCommand}" CommandParameter="{Binding SelectedItems, ElementName=PresetListBox}" Padding="0" Height="28" MinWidth="28" FontWeight="Bold" ToolTip="{x:Static loc:Texts.PresetManager_ApplyPreset}" HorizontalContentAlignment="Left" VerticalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="28">
                                        <Path Data="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z" Stretch="Uniform" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{x:Static loc:Texts.PresetManager_ApplyPreset}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource AnimatedTextBlockStyle}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Thumb Grid.Row="1" Height="6" Cursor="SizeNS" Margin="5,0,5,5" DragDelta="Thumb_DragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="2"/>
                                <RowDefinition Height="1"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Width="30" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                            <Border Grid.Row="2" Width="30" Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>